#
# FQDN of the acme server
# SERVER_NAME=<domain> (required)
SERVER_NAME="acme.example.org"

# Contact email
# CONTACT_EMAIL=<email> (required)
CONTACT_EMAIL="admine@example.org"

# Server secret key.
# SERVER_SECRET=changeme

# Name of the certificate repository
# CA_NAME=example

# Server URL.  Override the autogenerated URL.
# SERVER_URL="https://acme.example.org"

# ACME log file
# ACME_LOG=<path/file>

# ACME directory
# ACME_DIR=<path>

# Nonce expire seconds.  Time a nonce is valid for.
# NONCE_EXPIRE=60

# Maximum number of days a cert is valid
# MAX_CERT_DAYS=90

# Client retry time
# CLIENT_RETRY=3

# Time an order is valid.
# ORDER_EXPIRE=300

# Timeout for a verify process.
# VERIFY_TIMEOUT=5

# Retries for the verify process.
# VERIFY_RETRIES=3

# Delay between verify attempts
# VERIFY_DELAY=2
