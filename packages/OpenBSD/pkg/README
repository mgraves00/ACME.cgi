+-------------------------------------------------------------------------------
| Running ${PKGSTEM} on OpenBSD
+-------------------------------------------------------------------------------

In cases where ACME.cgi is to be used in a chroot environment (such as when running
behind webserver) there are several programs that are required.

# Copy helper programs to web chroot
	# create some directories
	install -d -m 1755 -o root -g wheel /var/www/tmp
	install -d -m 0755 -o root -g wheel /var/www/bin
	install -d -m 0755 -o root -g wheel /var/www/var/run
	# acme helper programs
	install -c -m 0555 -o root -g bin /bin/cat /var/www/bin/cat
	install -c -m 0555 -o root -g bin /bin/sleep /var/www/bin/sleep
	install -c -m 0555 -o root -g bin /bin/rm /var/www/bin/rm
	install -c -m 0555 -o root -g bin /usr/bin/cut /var/www/bin/cut
	install -c -m 0555 -o root -g bin /usr/bin/mktemp /var/www/bin/mktemp
	install -c -m 0555 -o root -g bin /usr/bin/host /var/www/bin/host
	install -c -m 0555 -o root -g bin /usr/bin/ftp /var/www/bin/ftp
	install -c -m 0555 -o root -g bin /usr/bin/fold /var/www/bin/fold
	install -c -m 0555 -o root -g bin /usr/bin/od /var/www/bin/od
	install -c -m 0555 -o root -g bin /usr/bin/openssl /var/www/bin/openssl
	install -c -m 0555 -o root -g bin /usr/bin/printf /var/www/bin/printf
	install -c -m 0555 -o root -g bin /usr/bin/wc /var/www/bin/wc
	install -c -m 0555 -o root -g bin /usr/local/bin/jq /var/www/bin/jq
	# setup libraries
	install -c -m 0644 -o root -g bin /usr/lib/libc.so.* /var/www/usr/lib
	install -c -m 0644 -o root -g bin /usr/lib/libm.so.* /var/www/usr/lib
	install -c -m 0644 -o root -g bin /usr/lib/libz.so.* /var/www/usr/lib
	install -c -m 0644 -o root -g bin /usr/lib/libutil.so.* /var/www/usr/lib
	install -c -m 0644 -o root -g bin /usr/lib/libssl.so.* /var/www/usr/lib
	install -c -m 0644 -o root -g bin /usr/lib/libcrypto.so.* /var/www/usr/lib
	install -c -m 0644 -o root -g bin /usr/lib/libtls.so.* /var/www/usr/lib
	install -c -m 0644 -o root -g bin /usr/lib/libssl.so.* /var/www/usr/lib
	install -c -m 0644 -o root -g bin /usr/lib/libedit.so.* /var/www/usr/lib
	install -c -m 0644 -o root -g bin /usr/lib/libcurses.so.* /var/www/usr/lib
	install -c -m 0644 -o root -g bin /usr/lib/libpthread.so.* /var/www/usr/lib
	install -c -m 0644 -o root -g bin /usr/local/lib/libjq.so.* /var/www/usr/local/lib
	install -c -m 0644 -o root -g bin /usr/local/lib/libonig.so.* /var/www/usr/local/lib
	# refresh ld.hints
	chroot /var/www ldconfig -v -s /usr/lib /usr/local/lib

# Enable slowcgi
	rcctl enable slowcgi
	rcctl start slowcgi

# Update /etc/httpd.conf.  See Example.

	# ACME.cgi httpd.conf
	SERVER_NAME="acme.example.org"
	server $SERVER_NAME {
		listen on * port 80
	# handle any ACME challenges for this server when running an acme client
	#	location "/.well-known/acme-challenge/*" {
	#		root "/acme"
	#		request strip 2
	#	}
		# otherwise return a 302 redirect
		location * {
			block return 302 "https://$HTTP_HOST$REQUEST_URI"
		}
	}
	server $SERVER_NAME {
		listen on 127.0.0.1 tls port 443
		tls {
			certificate "/etc/ssl/"$SERVER_NAME".fullchain.pem"
			key "/etc/ssl/private/"$SERVER_NAME".key"
		}
		location "/.well-known/acme-challenge/*" {
			root "/acme"
			request strip 2
		}
		location "/acme/*" {
			fastcgi {
				socket "/run/slowcgi.sock"
				param SCRIPT_FILENAME "/cgi-bin/ACME.cgi"
			}
		}
		# anything else just return error
		location * {
			block return 418 "I'm a teapot"
		}
	}

# Enable and start httpd
	rcctl enable httpd
	rcctl start httpd

# Update newsyslog to rotate log file.  Add the following
	/var/www/logs/acme.log                 644  7     250  *     Z "pkill -USR1 -u root -U root -x httpd"

# Configure PCA to work in chroot environment
	export CA_NAME="example.org"
	pca ${CA_NAME} init
	pca ${CA_NAME} config set macros -key PUBLICURL -value http://${ISSUER_DOMAIN}/ca
	pca ${CA_NAME} config set macros -key PATHLEN -value 2
	pca ${CA_NAME} config set prog -name prog_ca -a -key copy_extensions -value CopyAll
	pca ${CA_NAME} config set ext -name extension_acme -a -key basicConstraints -value critical,CA:FALSE
	pca ${CA_NAME} config set ext -name extension_acme -a -key keyUsage -value nonRepudiation,digitalSignature
	pca ${CA_NAME} config set ext -name extension_acme -a -key subjectKeyIdentifier -value hash
	pca ${CA_NAME} config set ext -name extension_acme -a -key authorityKeyIdentifier -value keyid
	pca ${CA_NAME} config set ext -name extension_acme -a -key extendedKeyUsage -value serverAuth,clientAuth
	pca ${CA_NAME} config set pol -name policy_sign -key commonName -value optional
	echo "creating Root cert"
	pca ${CA_NAME} create root -days 4000 -bits 4096 -cn "${CA_NAME} Root CA"
	echo "creating ACME RA cert"
	pca ${CA_NAME} create req -name ACME_RA -days 3650 -newkey 4096 -cn "${CA_NAME} ACME RA"
	pca ${CA_NAME} sign -name ACME_RA -sign
	echo "setting ACME_RA as signing cert"
	pca ${CA_NAME} config sign -name ACME_RA
	# create export the server certificate
	_a=`pca ${CA_NAME} show cert -name ${ISSUER_DOMAIN}`
	if [ -z "${_a}" ]; then
		echo "creating ${ISSUER_DOMAIN} cert"
		pca ${CA_NAME} create req -name ${ISSUER_DOMAIN} -newkey 2048 -cn "${ISSUER_DOMAIN}" -san "DNS=${ISSER_DOMAIN}"
		pca ${CA_NAME} sign -name ${ISSUER_DOMAIN} -days 365
	fi
	echo "exporting ${ISSUER_DOMAIN} cert"
	pca ${CA_NAME} create chain
	pca ${CA_NAME} export pkcs12 -name ${ISSUER_DOMAIN} -file /etc/ssl/${ISSUER_DOMAIN}.p12 -pass ${SERVER_SECRET} -chain -overwrite
	echo -n "${SERVER_SECRET}" > /etc/ssl/private/server.pass
	echo -n "${SERVER_SECRET}" > /etc/ssl/private/key.pass
	openssl pkcs12 -in /etc/ssl/${ISSUER_DOMAIN}.p12 -nocerts -out /etc/ssl/server.key -passin file:/etc/ssl/private/server.pass -passout file:/etc/ssl/private/key.pass
	openssl pkcs12 -in /etc/ssl/${ISSUER_DOMAIN}.p12 -nokeys -clcerts -out /etc/ssl/server.crt -passin file:/etc/ssl/private/server.pass
	openssl pkcs12 -in /etc/ssl/${ISSUER_DOMAIN}.p12 -nokeys -cacerts -out /etc/ssl/acme-roots.pem -passin file:/etc/ssl/private/server.pass
	cat /etc/ssl/server.crt /etc/ssl/acme-roots.pem > /etc/ssl/server.fullchain.pem
	rm -f /etc/ssl/private/key.pass

# setup ACME_cleaner.sh to run everyday
	# add the following to /etc/daily.local
	[[ -x /var/www/cgi-bin/ACME_cleaner.sh ]] && chroot /var/www /cgi-bin/ACME_cleaner.sh > /tmp/acme-cleaner.out

